<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;netstandard2.0</TargetFrameworks>
    <LangVersion>14</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>DotExtensions.Memory</PackageId>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <IncludeSymbols>true</IncludeSymbols>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <Version>10.0.0-alpha.4</Version>
    <Title>DotExtensions.Memory</Title>
    <Authors>Alastair Lundy</Authors>
    <Copyright>Copyright (c) Alastair Lundy 2025-2026</Copyright>
    <RepositoryUrl>https://github.com/alastairlundy/dotextensions</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <TrimmerSingleWarn>false</TrimmerSingleWarn>
    <IsTrimmable>true</IsTrimmable>
    <EnableAotAnalyzer>true</EnableAotAnalyzer>
    <IsAoTCompatible>true</IsAoTCompatible>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>### Breaking Changes
* Removed .NET 8 and .NET 9 TFMs ahead of .NET 8 &amp; 9 EOL - .NET 8 and .NET 9 remain supported via .NET Standard 2.0 TFM with limited support - Update to .NET 10 or newer for full support
* Made ``IsWhiteSpace`` extension methods private
* Removed additional deprecated code

### Non-Breaking Changes
* Improved helpfulness of some thrown exceptions
* Optimisations and improvements
* Updated internal Polyfill version to 9.13.0</PackageReleaseNotes>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
    <Description>A collection of useful extension members and extension methods for Span and Memory types in .NET.</Description>
    <PackageTags>extension-members, extensions, span, memory,</PackageTags>
    <PolyArgumentExceptions>true</PolyArgumentExceptions>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Meziantou.Analyzer"/>
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <PackageReference Include="Polyfill" PrivateAssets="all"/>
    <PackageReference Include="System.Memory"/>
  </ItemGroup>

  <ItemGroup>
    <Content Include="README.md">
      <PackagePath>README.md</PackagePath>
      <Link>README.md</Link>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Internal\Localizations\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Internal\Localizations\Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>
</Project>
