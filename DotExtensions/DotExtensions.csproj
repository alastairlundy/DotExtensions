<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <LangVersion>14</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <TargetFrameworks>net10.0;netstandard2.0</TargetFrameworks>
    <Title>DotExtensions</Title>
    <Authors>Alastair Lundy</Authors>
    <Copyright>Copyright (c) Alastair Lundy 2020-2026</Copyright>
    <RepositoryUrl>https://github.com/alastairlundy/DotExtensions</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>extensions, extension-members,extension-methods, ienumerable-extensions,</PackageTags>
    <PackageReleaseNotes>* Renamed Windows based file permission extension methods for extra clarity
* Reorganized Unix file permissions code into consolidated classes
* Improved performance of Unix Permission Notation detection
* Updated xml doc comments to use ``&lt;see langword=true&gt;`` and ``&lt;see langword=false&gt;`` instead of ``&lt;c&gt;true&lt;/c&gt;`` or ``&lt;c&gt;false&lt;/c&gt;``
* Moved file size labels to Resources resx file
* Moved Safe File Enumeration code and namespace
* Added ``GetNonNullPathRoot(string)`` and ``GetNonNullPathRoot(string?)`` static extension methods to ``Path`` - These method guarantees they will not return a null value.</PackageReleaseNotes>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <Description>A collection of useful extension members and extension methods for .NET .</Description>
    <IncludeSymbols>true</IncludeSymbols>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Version>10.0.0-alpha.5</Version>
    <PackageId>DotExtensions</PackageId>
      <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <TrimmerSingleWarn>false</TrimmerSingleWarn>
      <PolyArgumentExceptions>true</PolyArgumentExceptions>
      <NoWarn>$(NoWarn);CS0618</NoWarn>
  </PropertyGroup>

    <PropertyGroup Condition="$(TargetFramework) != 'netstandard2.0' OR $(TargetFramework) == 'netstandard2.1'">
        <IsAoTCompatible>true</IsAoTCompatible>
        <EnableAotAnalyzer>true</EnableAotAnalyzer>
    </PropertyGroup>
    
    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Primitives" />
        <PackageReference Include="Polyfill" PrivateAssets="all"/>
        <PackageReference Include="Meziantou.Analyzer" PrivateAssets="all"/>
        <PackageReference Include="System.IO.FileSystem.AccessControl"  Condition="'$(TargetFramework)' == 'netstandard2.0'"/>
    </ItemGroup>
    
    <ItemGroup>
    <Compile Update="Internal\Localizations\Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="DotExtensions.Benchmarking"/>
    </ItemGroup>
    
  <ItemGroup>
    <EmbeddedResource Update="Internal\Localizations\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\README.md">
      <Link>README.md</Link>
      <PackagePath>README.md</PackagePath>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="System\" />
  </ItemGroup>
</Project>
